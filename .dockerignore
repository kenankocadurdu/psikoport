# ─────────────────────────────────────────────────────────────
# Git
# ─────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─────────────────────────────────────────────────────────────
# Dependencies  (her app kendi layer'ında yükler)
# ─────────────────────────────────────────────────────────────
node_modules
apps/*/node_modules
packages/*/node_modules
.pnpm-store

# ─────────────────────────────────────────────────────────────
# Build Outputs
# ─────────────────────────────────────────────────────────────
apps/frontend/.next
apps/frontend/out
apps/api/dist
packages/*/dist
.turbo
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────
# Prisma — generated client (build sırasında üretilir)
# ─────────────────────────────────────────────────────────────
apps/api/src/generated

# ─────────────────────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.cert
*.p12

# ─────────────────────────────────────────────────────────────
# Tests & Coverage
# ─────────────────────────────────────────────────────────────
coverage
.nyc_output
test-results
playwright-report
blob-report
apps/*/e2e
apps/*/test
**/*.spec.ts
**/*.test.ts
**/*.e2e-spec.ts

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# IDE & Editor
# ─────────────────────────────────────────────────────────────
.idea
.vscode
*.swp
*.swo
.claude

# ─────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────
